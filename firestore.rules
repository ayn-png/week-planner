rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId}/weeklyPlans/{weekId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.weekId is string
        && request.resource.data.blocks is list;
    }

    match /users/{userId}/categories/{categoryId} {
      allow read, delete: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.label is string
        && request.resource.data.color is string
        && request.resource.data.color.matches('^#[0-9A-Fa-f]{3}([0-9A-Fa-f]{3})?$');
    }

    match /users/{userId}/metadata/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/weeklyExtras/{weekId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/goals/{goalId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/task_goal_mapping/{mapId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/activity_logs/{logId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── FCM Push Notification Tokens ──────────────────────────────────────────
    match /users/{userId}/fcmTokens/{tokenId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
